# ── 腾讯云 CVM 运行 ──
NODE_ENV=production
PORT=3050
HOST=0.0.0.0
# 前端在 Netlify、后端只提供 API 时设为 1（可不构建/不托管 dist/public）
API_ONLY=1
# Nginx / 负载均衡反代时保持 1（生产环境默认已开启 trust proxy）
TRUST_PROXY=1

# ── 文章 JSON 存储（无需数据库）──
# 不填则默认写入项目目录 data/articles.json
# ARTICLES_JSON_PATH=/var/www/senz-website1/data/articles.json

# ── 微信公众号（服务端，勿写入 Netlify 前端）──
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# POST /api/wechat/sync 的 Bearer Token（自行生成随机字符串）
WECHAT_SYNC_SECRET=

# Netlify 站点域名，逗号分隔；开发可留空（允许任意 Origin）
CORS_ORIGIN=https://your-site.netlify.app

# ── 可选：Netlify 前端调用后端 API 的基址 ──
# VITE_API_BASE_URL=https://api.your-domain.com
# 也可以直接指定 JSON 地址；优先级高于 VITE_API_BASE_URL
# VITE_ARTICLES_JSON_URL=https://api.your-domain.com/articles.json
